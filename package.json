{
  "name": "sentinelx",
  "version": "2.2.0",
  "description": "Live OSINT X account monitor",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "cross-env ELECTRON_RUN_AS_NODE= electron-vite preview",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.x",
    "@types/react": "^18.x",
    "@types/react-dom": "^18.x",
    "@vitejs/plugin-react": "^4.x",
    "autoprefixer": "^10.x",
    "cross-env": "^7.0.3",
    "electron": "^30.5.1",
    "electron-builder": "^24.x",
    "electron-vite": "^2.x",
    "postcss": "^8.x",
    "tailwindcss": "^3.x",
    "typescript": "^5.x",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "electron-store": "^8.x",
    "react": "^18.x",
    "react-dom": "^18.x"
  },
  "build": {
    "appId": "com.sentinelx.app",
    "productName": "SentinelX",
    "win": {
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.news"
    },
    "directories": {
      "output": "dist"
    }
  }
}
